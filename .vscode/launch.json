{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Demo",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\run_demo.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      }
    },
    {
      "name": "Run Demo (JSON)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\run_demo.py",
      "args": [
        "--json"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      }
    },
    {
      "name": "Start API",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\start_api.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      }
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-s",
        "tests",
        "-v"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}\\src"
      }
    }
  ]
}
