DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=45

# Environment: dev|test keep open auth for local demos; production requires MAS_API_KEY.
# In production, DATA_MODE defaults to live and local fallback defaults to disabled.
APP_ENV=dev
MAS_API_KEY=

# Data contract: demo allows SAMPLE_FINANCIAL_DATA; live disables silent sample fundamentals.
# demo = allow SAMPLE_FINANCIAL_DATA; live = PDF/live sources only
DATA_MODE=live
# When live (default true): fetch Yahoo annual income-statement fundamentals if no upload metrics
MAS_FETCH_LIVE_FUNDAMENTALS=true
# Prefer SEC EDGAR companyfacts for US tickers (falls back to Yahoo on miss)
MAS_FETCH_SEC_FUNDAMENTALS=true
# Optional: SEC fair-access User-Agent with your contact email
# SEC_USER_AGENT=LumenFinAgent/0.1 (yourname@example.com)

# When unset: allowed in dev/test, disabled in production. Set true only for explicit demos.
# ALLOW_LOCAL_FALLBACK=false

# Upload limits
MAS_MAX_UPLOAD_BYTES=20971520
MAS_MAX_UPLOAD_FILES=5

# Milvus Lite RAG (no Docker required). Single-process only — do not share one Lite file across API+CLI+worker.
# By default each process uses data/milvus_lite_p{PID}.db (MAS_MILVUS_ISOLATE=true) to avoid lock errors.
MAS_RAG_ENABLED=true
MAS_MILVUS_URI=data/milvus_lite.db
MAS_MILVUS_ISOLATE=true
MAS_MILVUS_COLLECTION=lumenfin_chunks
MAS_EMBEDDING_PROVIDER=deterministic
# Optional: pip install fastembed && set MAS_EMBEDDING_PROVIDER=fastembed
MAS_EMBEDDING_DIMENSION=384
MAS_RAG_TOP_K=5
MAS_CRITIC_MAX_ITERATIONS=2

# Quant tool transport: local (in-process) or mcp (stdio MCP server)
MAS_TOOL_BACKEND=local

# MCP document search: auto | keyword | milvus
MAS_MCP_DOC_SEARCH=auto

# Market data — primary + fallback with TTL cache
MAS_MARKET_DATA_PROVIDER=alphavantage
MAS_MARKET_DATA_FALLBACK=yahoo
# Yahoo fallback uses the yfinance library (already in dependencies), not raw Yahoo HTTP API.
MAS_MARKET_CACHE_TTL_SECONDS=60
# Free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
